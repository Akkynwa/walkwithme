// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL") // Added directUrl for structural migrations
}

model User {
  id                    String                @id @default(cuid())
  email                 String                @unique
  emailVerified         DateTime?
  name                  String?
  image                 String?               @db.Text
  bio                   String?               @db.Text
  password              String?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  passwordResetToken    String?               @unique
  passwordResetExpires  DateTime?
  emailNotifications    Boolean               @default(true)
  pushNotifications     Boolean               @default(true)
  dailyReminder         Boolean               @default(true)
  prayerReminder        Boolean               @default(true)
  newContent            Boolean               @default(true)

  // --- COHORT & WORKSPACE RELATIONS ---
  shares                CommunityShare[]      @relation("UserShares")
  amens                 Amen[]                @relation("UserAmens")
  prayerRequests        PrayerRequest[]       @relation("UserPrayerRequests")
  intercessions         Intercession[]        @relation("UserIntercessions")
  cohortMember          CohortMember?         @relation("UserCohortMember")
  cohortMessages        CohortMessage[]       @relation("UserCohortMessages")

  // --- DYNAMIC COMMUNITY FELLOWSHIP GROUPS ---
  groupMemberships      GroupMember[]         @relation("UserGroupMemberships")
  createdGroups         CommunityGroup[]      @relation("UserCreatedGroups")

  // --- LEGACY & SYSTEM RELATIONS ---
  accounts              Account[]
  sessions              Session[]
  journalEntries        JournalEntry[]
  prayers               Prayer[]              
  quietTimeSessions     QuietTimeSession[]
  communityMemberships  CommunityMembership[]
  userPreferences       UserPreferences?
  streakData            StreakData?
  discussions           Discussion[]
  replies               Reply[]
  auditLogs             AuditLog[]
  messages              Message[]             
  currentStreak         Int                   @default(0)
  longestStreak         Int                   @default(0)
  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
}

model VerificationToken {
  id         String   @id @default(cuid())
  identifier String
  token      String   @unique
  expires    DateTime
  
  @@unique([identifier, token])
}

model UserPreferences {
  id                  String   @id @default(cuid())
  userId              String   @unique
  language            String   @default("en")
  theme               String   @default("light")
  fontSize            Int      @default(2)      
  
  // Bible Sub-Preferences fields
  bibleTranslation    String   @default("KJV")
  readingMode         String   @default("verse")
  showCrossReferences Boolean  @default(true)
  showCommentary      Boolean  @default(true)
  
  // Notification Sub-Preferences fields
  dailyVerseReminder  Boolean  @default(true)
  journalPrompts      Boolean  @default(true)
  weeklySummary       Boolean  @default(false)
  
  // Deprecated legacy matching parameters for backwards compatibility 
  notifications       Boolean  @default(true)
  dailyReminder       Boolean  @default(true)

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model JournalEntry {
  id        String   @id @default(cuid())
  userId    String
  title     String
  content   String   @db.Text
  mood      String?
  tags      String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId, createdAt])
}

model Prayer {
  id          String    @id @default(cuid())
  userId      String
  title       String
  description String    @db.Text
  category    String
  status      String    @default("pending")
  answeredAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId, status])
}

model QuietTimeSession {
  id        String   @id @default(cuid())
  userId    String
  type      String   
  duration  Int      
  scripture String?
  notes     String?  @db.Text
  createdAt DateTime @default(now())
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId, createdAt])
}

model Community {
  id          String   @id @default(cuid())
  name        String
  description String   @db.Text
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  groups  CommunityGroup[]
  members CommunityMembership[]
}

model CommunityGroup {
  id          String        @id @default(cuid())
  communityId String?       // Made optional so groups can exist inside a parent organization or standalone
  firstName   String?               // Added field
  lastName    String?               // Added field
  name        String
  description String        @db.Text
  category    String        // 'Bible Study', 'Meditation', 'Prayer', etc.
  image       String
  isFeatured  Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  creatorId   String
  
  // Unified Relational Fields
  community   Community?    @relation(fields: [communityId], references: [id], onDelete: Cascade)
  creator     User          @relation("UserCreatedGroups", fields: [creatorId], references: [id], onDelete: Cascade)
  members     GroupMember[]
  discussions Discussion[]
  
  @@index([communityId])
  @@index([category])
}

model GroupMember {
  id        String         @id @default(cuid())
  userId    String
  groupId   String
  joinedAt  DateTime       @default(now())
  
  user      User           @relation("UserGroupMemberships", fields: [userId], references: [id], onDelete: Cascade)
  group     CommunityGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
}

model CommunityMembership {
  id          String   @id @default(cuid())
  userId      String
  communityId String
  role        String   @default("member") // member, moderator, admin
  joinedAt    DateTime @default(now())
  
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  
  @@unique([userId, communityId])
  @@index([userId])
}

model Discussion {
  id        String   @id @default(cuid())
  groupId   String
  title     String
  content   String   @db.Text
  authorId  String   
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  group     CommunityGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  author    User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  replies   Reply[]
  
  @@index([groupId])
  @@index([authorId])
}

model Reply {
  id           String     @id @default(cuid())
  discussionId String
  authorId     String   
  content      String     @db.Text
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  
  discussion   Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  
  @@index([discussionId])
  @@index([authorId])
}

model StreakData {
  id            String   @id @default(cuid())
  userId        String   @unique
  currentStreak Int      @default(0)
  longestStreak Int      @default(0)
  lastActiveAt  DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  details   String?  @db.Text
  createdAt DateTime @default(now())
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId, createdAt])
}

model Message {
  id        String   @id // Modified: Removed default cuid handler so client hook string IDs match directly
  content   String   @db.Text
  role      String   
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Testimony {
  id         String   @id @default(cuid())
  author     String
  location   String
  content    String   @db.Text
  isApproved Boolean  @default(false) 
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("testimonies") 
}

model UserPathProgress {
  id          String    @id @default(cuid())
  userId      String
  nodeId      String    
  isCompleted Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([userId, nodeId]) 
  @@map("user_path_progress")
}

model CommunityShare {
  id          String   @id @default(cuid())
  userId      String
  book        String
  chapter     Int
  content     String   @db.Text
  isAnonymous Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation("UserShares", fields: [userId], references: [id], onDelete: Cascade)
  amens       Amen[]

  @@index([userId])
}

model Amen {
  id               String         @id @default(cuid())
  communityShareId String
  userId           String
  createdAt        DateTime       @default(now())

  communityShare   CommunityShare @relation(fields: [communityShareId], references: [id], onDelete: Cascade)
  user             User           @relation("UserAmens", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([communityShareId, userId])
  @@index([userId])
}

model PrayerRequest {
  id           String        @id @default(cuid())
  userId       String
  content      String        @db.Text
  isAnonymous  Boolean       @default(false)
  status       PrayerStatus  @default(ACTIVE)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  user         User          @relation("UserPrayerRequests", fields: [userId], references: [id], onDelete: Cascade)
  intercessors Intercession[]

  @@index([userId])
}

enum PrayerStatus {
  ACTIVE
  ANSWERED
}

model Intercession {
  id              String        @id @default(cuid())
  prayerRequestId String
  userId          String
  createdAt       DateTime      @default(now())

  prayerRequest   PrayerRequest @relation(fields: [prayerRequestId], references: [id], onDelete: Cascade)
  user            User          @relation("UserIntercessions", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([prayerRequestId, userId])
  @@index([userId])
}

model Cohort {
  id        String          @id @default(cuid())
  name      String          @unique
  createdAt DateTime        @default(now())
  
  members   CohortMember[]
  messages  CohortMessage[]
}

model CohortMember {
  id        String   @id @default(cuid())
  cohortId  String
  userId    String   @unique
  createdAt DateTime @default(now())

  cohort    Cohort   @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  user      User     @relation("UserCohortMember", fields: [userId], references: [id], onDelete: Cascade)

  @@index([cohortId])
}

model CohortMessage {
  id        String   @id @default(cuid())
  cohortId  String
  userId    String
  text      String   @db.Text
  createdAt DateTime @default(now())

  cohort    Cohort   @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  user      User     @relation("UserCohortMessages", fields: [userId], references: [id], onDelete: Cascade)

  @@index([cohortId])
  @@index([userId])
}